# ============================================================
# Earn4Insights — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
POSTGRES_URL=postgresql://user:password@host:5432/dbname

# ── Authentication (NextAuth v5) ─────────────────────────────
AUTH_SECRET=               # openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Admin & Cron ─────────────────────────────────────────────
ADMIN_API_KEY=             # Strong random key for admin API routes
ANALYTICS_ADMIN_SECRET=    # Optional: separate key for /api/admin/analytics
CRON_SECRET=               # Secret for cron job endpoints
IMPORT_WEBHOOK_API_KEY=    # Key for import webhook endpoints

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@earn4insights.com
NOTIFICATION_EMAIL=        # Optional: override notification sender

# ── WhatsApp (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=      # e.g. whatsapp:+14155238886

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=
# Optional model overrides (defaults are used if not set):
# OPENAI_SCORING_MODEL=
# OPENAI_STT_MODEL=
# OPENAI_TEXT_MODEL=
# OPENAI_THEME_MODEL=

# ── Encryption ───────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── App URLs ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.earn4insights.com
# NEXT_PUBLIC_BASE_URL=    # Optional: override for digest emails

# ── Analytics ────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Social Platform APIs (optional) ─────────────────────────
# YOUTUBE_API_KEY=
# GOOGLE_PLACES_API_KEY=
# TWITTER_BEARER_TOKEN=
# META_ACCESS_TOKEN=
# INSTAGRAM_ACCESS_TOKEN=
# LINKEDIN_ACCESS_TOKEN=
# TIKTOK_API_KEY=
# AMAZON_SCRAPER_URL=
# FLIPKART_SCRAPER_URL=

# ── Media Processing (optional overrides) ────────────────────
# FEEDBACK_MEDIA_MAX_RETRIES=3
# FEEDBACK_MEDIA_PROCESSING_TIMEOUT_SECONDS=30
# FEEDBACK_MEDIA_RETRY_BACKOFF_BASE_SECONDS=60
# AUDIO_MEDIA_RETENTION_DAYS=90
# VIDEO_MEDIA_RETENTION_DAYS=90
# ALLOW_MANUAL_MEDIA_PROCESSING=false
# NORMALIZED_LANGUAGE=en
