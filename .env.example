# Environment Variables

# Admin API Key for protected endpoints
ADMIN_API_KEY=your-secure-api-key-here

# Resend Email Service
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=rankings@yourdomain.com

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================
# Social Listening API Keys
# ========================

# YouTube Data API v3 (free: 10,000 units/day)
# Get from: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key-here

# Google Places API (free: $200/mo credit covers ~13,000 requests)
# Get from: https://console.cloud.google.com → APIs & Services → Places API
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# Twitter/X API v2 (Basic: $100/mo, 10K reads/mo)
# TWITTER_BEARER_TOKEN=your-twitter-bearer-token-here

# ========================
# Encryption Configuration
# ========================

# CRITICAL: Generate a secure 256-bit encryption key
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 
# NEVER commit this key to git!
# Use different keys for dev/staging/production
#
ENCRYPTION_KEY=your-base64-encoded-256-bit-key-here

# Example (DO NOT USE THIS - GENERATE YOUR OWN):
# ENCRYPTION_KEY=5K8x9mP2nQ7wR3vL6jH4tY1uA8sD0fG5N9mB2cV7xZ4=
